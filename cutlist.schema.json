{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "剪单 cut-list",
  "description": "A/B 两线共享的剪辑决策契约:agent 的决策层产出它,操作层(剪映 CapCutAPI / Resolve MCP)只负责物化它。时间单位一律秒。",
  "type": "object",
  "required": ["note_id", "segments"],
  "properties": {
    "note_id": { "type": "string", "description": "笔记表排期编号,如 PQ-012" },
    "sku": { "type": "string", "description": "衣服编号,如 GY-003" },
    "canvas": {
      "type": "object",
      "properties": {
        "width": { "type": "integer", "default": 1080 },
        "height": { "type": "integer", "default": 1920 }
      }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "description": "按时间线顺序;main 依次首尾相接,ai_ref 与同段 main 同起点对齐",
      "items": {
        "type": "object",
        "required": ["seq", "main"],
        "properties": {
          "seq": { "type": "integer", "description": "分镜段号,对应文件名 S{seq}" },
          "main": {
            "type": "object",
            "required": ["file", "in", "out"],
            "description": "主轨素材:实拍,或直接采用 AI 片(AI/实拍混剪即在此选择)",
            "properties": {
              "file": { "type": "string", "description": "素材绝对路径或相对素材库根的路径" },
              "in": { "type": "number", "description": "源内入点(秒)" },
              "out": { "type": "number", "description": "源内出点(秒)" },
              "speed": { "type": "number", "default": 1.0 },
              "volume": { "type": "number", "default": 1.0 },
              "transition": { "type": ["string", "null"], "description": "到下一段的转场类型,null=硬切" }
            }
          },
          "ai_ref": {
            "type": ["object", "null"],
            "description": "AI 参考片:画中画静音叠在角落,供人精修时对照;null=该段不摆参考",
            "properties": {
              "file": { "type": "string" },
              "in": { "type": "number", "default": 0 },
              "out": { "type": "number" }
            }
          },
          "subtitle": { "type": ["string", "null"], "description": "该段字幕文本(可选)" },
          "rationale": { "type": ["string", "null"], "description": "agent 的剪辑理由(为什么选这段这个窗口),人审时看" }
        }
      }
    }
  }
}
